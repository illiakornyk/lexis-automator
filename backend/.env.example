FREE_DICTIONARY_API_URL=https://api.dictionaryapi.dev/api/v2/entries/en/

# LLM — choose one provider: openrouter | openai | gemini | anthropic
LLM_PROVIDER=openrouter
LLM_API_KEY=your_key_here
# LLM_MODEL=openai/gpt-4o-mini   # optional — defaults per provider if omitted

GOOGLE_APPLICATION_CREDENTIALS=google-credentials.json

SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

REDIS_URL=redis://localhost:6379
PIXABAY_API_KEY=your_pixabay_key_here

# ANKI_EXPORTER_URL=http://127.0.0.1:8000   # optional
# PORT=3000                                   # optional
