FREE_DICTIONARY_API_URL=https://api.dictionaryapi.dev/api/v2/entries/en/

# LLM — choose one provider: openrouter | openai | gemini | anthropic
LLM_PROVIDER=openrouter
LLM_API_KEY=your_key_here
# LLM_MODEL=openai/gpt-4o-mini   # optional — defaults per provider if omitted

GOOGLE_TTS_API_KEY=your_google_tts_api_key_here

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

REDIS_URL=redis://localhost:6379
PIXABAY_API_KEY=your_pixabay_key_here

# ANKI_EXPORTER_URL=http://127.0.0.1:8000   # optional
# PORT=3000                                   # optional
# APP_URL=http://localhost:3000               # optional — sent as HTTP-Referer to OpenRouter
# CORS_ORIGINS=http://localhost:3001          # optional, comma-separated. Defaults to http://localhost:3001
